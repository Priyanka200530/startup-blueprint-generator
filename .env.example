# ============================================================
# Startup Blueprint Generator – Environment Variables
# ============================================================
# Copy this file to .env and fill in your credentials.
# NEVER commit .env to version control.
#
# ┌─────────────────────────────────────────────────────────┐
# │  BACKEND PRIORITY (app tries these in order)            │
# │  1. Orchestrate  → WATSONX_URL + WATSONX_API_KEY        │
# │  2. Granite      → WATSONX_API_KEY + WATSONX_PROJECT_ID │
# │  3. Demo mode    → no credentials needed (built-in data)│
# └─────────────────────────────────────────────────────────┘

# ----------------------------------------------------------
# IBM Cloud API Key  (required for both Orchestrate & Granite)
# ----------------------------------------------------------
# Get from: IBM Cloud → Manage → Access (IAM) → API Keys → Create
WATSONX_API_KEY=your_ibm_cloud_api_key_here

# ----------------------------------------------------------
# IBM watsonx Orchestrate  ← YOUR SETUP
# ----------------------------------------------------------
# Your Orchestrate instance base URL.
# The app automatically calls:  POST <WATSONX_URL>/v1/chat
# Get from: IBM Cloud → Services → watsonx Orchestrate → Service credentials
WATSONX_URL=https://api.eu-gb.watson-orchestrate.cloud.ibm.com/instances/your_instance_id_here

# IBM Cloud region for your Orchestrate instance (eu-gb, us-south, etc.)
WATSONX_REGION=eu-gb

# (Optional) ID of a specific agent inside the instance.
# Leave blank to use the default/only agent in the instance.
# Get from: watsonx Orchestrate UI → Agents → click your agent → copy ID from the URL
ORCHESTRATE_AGENT_ID=

# (Optional) Override the auto-built chat endpoint entirely.
# Leave blank – WATSONX_URL above is sufficient for standard instances.
ORCHESTRATE_AGENT_URL=

# ----------------------------------------------------------
# IBM Granite via watsonx.ai  ← OPTIONAL FALLBACK
# ----------------------------------------------------------
# Only needed if you want Granite directly (not via Orchestrate).
# Get from: IBM Cloud → Watson Studio → Your Project → Manage → General → Project ID
WATSONX_PROJECT_ID=

# Granite model to use for direct watsonx.ai calls
GRANITE_MODEL_ID=ibm/granite-13b-instruct-v2

# ----------------------------------------------------------
# RAG Knowledge Base – Watson Discovery  ← OPTIONAL
# ----------------------------------------------------------
DISCOVERY_API_KEY=
DISCOVERY_URL=https://api.eu-gb.discovery.watson.cloud.ibm.com
DISCOVERY_PROJECT_ID=
DISCOVERY_COLLECTION_ID=

# ----------------------------------------------------------
# Flask Application
# ----------------------------------------------------------
SECRET_KEY=sbg-change-me-to-a-long-random-secret
FLASK_ENV=development
PORT=5000
