# ============================================================
# Startup Blueprint Generator – Environment Variables
# ============================================================
# Copy this file to .env and fill in your real credentials.
# NEVER commit the .env file to version control.

# ----------------------------------------------------------
# IBM watsonx Orchestrate
# ----------------------------------------------------------
# Your IBM Cloud API Key (IAM)
WATSONX_API_KEY=

# IBM watsonx Orchestrate / watsonx.ai service URL
# e.g. https://us-south.ml.cloud.ibm.com
WATSONX_URL=

# IBM Cloud region (e.g. us-south, eu-de, jp-tok)
WATSONX_REGION=api.eu-gb

# watsonx.ai project ID (found in the project settings)
WATSONX_PROJECT_ID=your_watsonx_project_id_here

# IBM watsonx Orchestrate Agent / Skill-flow endpoint
# -------------------------------------------------------
# OPTIONAL – if left blank, the app auto-builds the endpoint from WATSONX_URL.
# For a standard Orchestrate instance the auto-built URL is:
#   <WATSONX_URL>/v1/chat
# Only set this explicitly if you have a specific agent chat-completions URL,
# e.g. https://api.ibm.com/watsonx-orchestrate/run/v1/agents/<agent_id>/chat/completions
ORCHESTRATE_AGENT_URL=https://eu-gb.watson-orchestrate.cloud.ibm.com/build/agent/edit/5e680486-334f-445b-83ba-fb989563210b

# IBM Granite model ID used for blueprint generation
GRANITE_MODEL_ID=ibm/granite-13b-instruct-v2

# ----------------------------------------------------------
# RAG Knowledge Base
# ----------------------------------------------------------
# Watson Discovery collection used as the RAG data source
DISCOVERY_API_KEY=your_watson_discovery_api_key_here
DISCOVERY_URL=https://api.us-south.discovery.watson.cloud.ibm.com
DISCOVERY_PROJECT_ID=your_discovery_project_id_here
DISCOVERY_COLLECTION_ID=your_discovery_collection_id_here

# ----------------------------------------------------------
# Flask Application
# ----------------------------------------------------------
# Secret key for Flask sessions – change to a long random string
SECRET_KEY=change_me_to_a_long_random_secret_key

# Run mode: development | production
FLASK_ENV=development

# Port the Flask dev-server listens on
PORT=5000
